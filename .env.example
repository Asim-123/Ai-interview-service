# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# OpenRouter (used for AI answers AND audio transcription via Gemini 2.0 Flash)
OPENROUTER_API_KEY=your-openrouter-api-key

# Polar.sh — create products at https://polar.sh/dashboard and copy their IDs here
PAYMENT_PROVIDER=polar
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_MODE=sandbox
POLAR_SUCCESS_URL=https://yourdomain.com/payment/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=polar_whs_xxx
NEXT_PUBLIC_POLAR_ORGANIZATION_ID=your-org-id
POLAR_STARTER_PRODUCT_ID=your-starter-product-id
POLAR_PRO_PRODUCT_ID=your-pro-product-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
